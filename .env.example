# Root Environment Variables
# Use this for local shared configuration or generic settings

# Example: postgresql://postgres:password@localhost:5432/discharge_buddy
DATABASE_URL=your_database_url_here

# App environment (development | production | test)
NODE_ENV=development

# Server port
PORT=3000

# JWT Secret for authentication
JWT_SECRET=super_secret_dev_jwt_key

# Anthropic API key for Language Simplifier feature (optional — falls back to dictionary-only mode)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs TTS (optional — falls back to device speech if not set)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here
# EXPO_PUBLIC_ prefix makes this visible to the Expo/React Native client
EXPO_PUBLIC_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
